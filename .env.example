# Jira (optional — tools only register if these are set)
JIRA_BASE_URL=https://pathwise.atlassian.net
JIRA_EMAIL=you@pathwisek12.com
JIRA_TOKEN=<atlassian-api-token>

# GitHub (optional — tools only register if GH_TOKEN is set)
GH_TOKEN=your-github-token

# Optional: comma-separated list of repos to search (defaults to TransActComm org repos)
# GH_REPOS=TransActComm/TravelTracker,TransActComm/Portage-backend,TransActComm/Portage-frontend

# Figma (optional — tools only register if FIGMA_TOKEN is set)
FIGMA_TOKEN=your-figma-personal-access-token

# Confluence (optional) — Confluence Cloud reuses your Atlassian (Jira) credentials,
# so the tools register automatically whenever the JIRA_* vars above are set.
# Set these only to point Confluence at a different site/account than Jira:
# CONFLUENCE_BASE_URL=https://pathwise.atlassian.net   # bare site or .../wiki both work
# CONFLUENCE_EMAIL=you@pathwisek12.com
# CONFLUENCE_TOKEN=<atlassian-api-token>

# Jenkins (optional — tools only register if all three are set)
# Prefer a Jenkins API token (<JENKINS_URL>/user/<you>/configure) over your account password.
# Use https:// if the server offers it — Basic auth sends the token on every request.
JENKINS_URL=http://jedi.onecampus.com:8080
JENKINS_USER=your-jenkins-username
JENKINS_TOKEN=your-jenkins-api-token

# toolkit-mcp server
MCP_TRANSPORT=stdio         # stdio or http
MCP_PORT=3000               # only used for http transport
MCP_LOG_LEVEL=info          # silent | info | debug
